            prices: [
                { item: "iPhone 15 Pro Max", price: "5,150 CNY", trend: "down" },
                { item: "MacBook Air M2", price: "4,800 CNY", trend: "stable" },
                { item: "AirPods Pro 2", price: "185 CNY", trend: "hot" },
