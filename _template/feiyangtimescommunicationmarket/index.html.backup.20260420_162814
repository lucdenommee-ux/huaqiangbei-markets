            ],
            shipping: "Normal",
            lastUpdate: new Date().toLocaleDateString('en-US')
        };

        function updateTicker() {
            const container = document.getElementById('ticker-content');
            let html = '';
            marketData.prices.forEach(p => {
                let icon = p.trend === 'down' ? '📉' : (p.trend === 'hot' ? '🔥' : '✅');
                html += `<span>${icon} ${p.item}: <strong>${p.price}</strong></span>`;
            });
            html += `<span>📦 Shipping: ${marketData.shipping}</span>`;
            html += `<span>📅 Updated: ${marketData.lastUpdate}</span>`;
            // Dupliquer pour défilement infini
            container.innerHTML = html + html;
        }
        document.addEventListener('DOMContentLoaded', updateTicker);
    </script>
