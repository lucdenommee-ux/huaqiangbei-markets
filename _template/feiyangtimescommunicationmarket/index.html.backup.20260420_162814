        /* Ticker */
        .ticker-wrapper {
            background: #1a1a1a;
            color: var(--neon-green);
            padding: 10px 0;
            display: flex;
            overflow: hidden;
            font-family: 'Courier New', Courier, monospace;
            border-bottom: 2px solid #333;
            margin-bottom: 20px;
        }
        .ticker-title {
            background: #ff0000;
            color: white;
            padding: 0 20px;
            font-weight: bold;
            z-index: 2;
            white-space: nowrap;
        }
        .ticker-content {
            display: flex;
            white-space: nowrap;
            animation: ticker 35s linear infinite;
        }
        .ticker-content span {
            padding-left: 40px;
        }
        @keyframes ticker {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        /* Status badge */
        .status-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 4px;
            font-size: 0.9rem;
            text-transform: uppercase;
            background: rgba(0, 255, 65, 0.1);
            border: 1px solid var(--neon-green);
            color: var(--neon-green);
            margin-left: 15px;
        }
        /* Bundles */
        .bundles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin: 40px 0;
        }
        .bundle-card {
            background: #1e1e1e;
            border: 1px solid #333;
            border-radius: 20px;
            padding: 30px 25px;
            position: relative;
            transition: transform 0.3s, border-color 0.3s;
        }
        .bundle-card:hover {
            transform: translateY(-10px);
            border-color: #ff0000;
        }
        .bundle-badge {
            position: absolute;
            top: -12px;
            right: 20px;
            background: #ff0000;
            padding: 6px 16px;
            font-size: 12px;
            font-weight: bold;
            border-radius: 30px;
            color: white;
        }
        .bundle-price {
            margin: 20px 0;
        }
        .old-price {
            text-decoration: line-through;
            color: #888;
            font-size: 14px;
        }
        .new-price {
            display: block;
            font-size: 28px;
            color: var(--neon-green);
            font-weight: bold;
        }
        .bundle-features {
            list-style: none;
            padding: 0;
            margin: 0 0 25px;
            font-size: 14px;
        }
        .bundle-features li {
            margin-bottom: 10px;
        }
        .bundle-btn {
            display: block;
            text-align: center;
            background: #25d366;
            color: white;
            text-decoration: none;
            padding: 14px;
            border-radius: 40px;
            font-weight: bold;
            box-shadow: 0 0 15px rgba(37, 211, 102, 0.3);
            transition: all 0.3s;
        }
        .bundle-btn:hover {
            box-shadow: 0 0 25px rgba(37, 211, 102, 0.6);
            transform: scale(1.02);
        }
